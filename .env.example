# Brevo (ex-Sendinblue) API Key
# Créez un compte gratuit sur https://brevo.com
# Générez votre clé API dans : Paramètres > Clés API & Tokens
VITE_BREVO_API_KEY=your_brevo_api_key_here

# ID de la liste de contacts Brevo pour le livre blanc
# Créez une liste "Livre Blanc" dans Brevo > Contacts > Listes
VITE_BREVO_LIST_ID=2

# ID du template d'email automatique dans Brevo
# Créez un template dans Brevo > Templates d'emails
VITE_BREVO_TEMPLATE_ID=1
